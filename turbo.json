{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["lint"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"start": {
			"dependsOn": ["build"],
			"persistent": true,
			"cache": true
		},
		"lint": {},
		"format": {},
		"test": {}
	}
}
